---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-col">
        <img src="/assets/Win-Win%20apps.png" alt="Win-Win Apps" width="40" height="40" style="border-radius:8px;margin-bottom:12px" />
        <p style="font-size:14px;color:rgba(255,248,243,0.7);margin:0 0 12px">Simple Shopify apps that help merchants grow and help their customers stay happy.</p>
      </div>
      <div class="footer-col">
        <h4>Products</h4>
        <ul>
          <li><a href="/apps/win-win-store-credit/">Store Credit</a></li>
          <li><a href="/apps/win-win-product-badges/">Product Badges</a></li>
          <li><a href="/apps/">All apps</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Resources</h4>
        <ul>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/best/">Best-of guides</a></li>
          <li><a href="/compare/">Compare apps</a></li>
          <li><a href="/how-to/">How-to guides</a></li>
          <li><a href="/category/conversion/">Conversion apps</a></li>
          <li><a href="/category/loyalty/">Loyalty apps</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/about/">About</a></li>
          <li><a href="/contact/">Contact</a></li>
          <li><a href="/investors/">Investors</a></li>
          <li><a href="/privacy/">Privacy</a></li>
          <li><a href="/terms/">Terms</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {year} Win-Win Apps. All rights reserved.</span>
      <a href="https://apps.shopify.com/partners/win-win-apps" target="_blank" rel="noopener">
        <img src="/assets/badge-shopify-app-store-dark.png" alt="Shopify App Store" width="120" height="auto" />
      </a>
    </div>
  </div>
</footer>
