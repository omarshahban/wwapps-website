---
interface Props {
  date?: string;
  cutoff?: string;
  compact?: boolean;
}
const { date = "Thursday, Apr 30", cutoff = "Order in 3h 12m", compact = false } = Astro.props;
---
<div class={`delivery-line ${compact ? "delivery-line-compact" : ""}`} aria-hidden="true">
  <span class="delivery-line-icon">
    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="8" width="13" height="9" rx="1"/>
      <path d="M16 11h3l2 3v3h-5z"/>
      <circle cx="7" cy="19" r="2"/>
      <circle cx="17" cy="19" r="2"/>
    </svg>
  </span>
  <div class="delivery-line-text">
    <div class="delivery-line-main">Delivery by <strong>{date}</strong></div>
    <div class="delivery-line-sub">{cutoff}</div>
  </div>
</div>

<style>
.delivery-line {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  padding: 10px 14px;
  background: #fff;
  border: 1px solid rgba(58, 46, 42, 0.12);
  border-radius: 10px;
  color: #3a2e2a;
}
.delivery-line-compact {
  padding: 8px 12px;
}
.delivery-line-icon { color: #2e6b43; display: inline-flex; }
.delivery-line-main { font-size: 14px; line-height: 1.3; }
.delivery-line-main strong { color: #2e6b43; }
.delivery-line-sub { font-size: 12px; color: rgba(58, 46, 42, 0.6); }
</style>
