---
interface Step {
  title: string;
  body: string;
  icon?: string;
}
interface Props {
  steps: Step[];
}
const { steps } = Astro.props;
---
<div class="step-flow">
  {steps.map((step, i) => (
    <div class="step-flow-item">
      <div class="step-flow-num">{i + 1}</div>
      {step.icon && <div class="step-flow-icon" aria-hidden="true">{step.icon}</div>}
      <h4 class="step-flow-title">{step.title}</h4>
      <p class="step-flow-body">{step.body}</p>
    </div>
  ))}
</div>

<style>
.step-flow {
  display: grid;
  grid-template-columns: 1fr;
  gap: 20px;
  margin: 32px 0;
}
@media (min-width: 640px) {
  .step-flow {
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
}
.step-flow-item {
  background: #fff;
  border: 1px solid rgba(58, 46, 42, 0.12);
  border-radius: 14px;
  padding: 24px;
  position: relative;
}
.step-flow-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 32px;
  height: 32px;
  border-radius: 999px;
  background: #a53630;
  color: #fff;
  font-weight: 700;
  font-size: 14px;
  margin-bottom: 14px;
}
.step-flow-icon { font-size: 28px; margin-bottom: 10px; }
.step-flow-title {
  margin: 0 0 6px;
  font-size: 17px;
  font-weight: 700;
  color: #3a2e2a;
}
.step-flow-body {
  margin: 0;
  font-size: 14px;
  line-height: 1.55;
  color: rgba(58, 46, 42, 0.75);
}
</style>
