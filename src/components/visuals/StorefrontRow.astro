---
// A row of 3 ProductMock slots. Pass children in any order, they will flow.
---
<div class="storefront-row" aria-hidden="true">
  <slot />
</div>

<style>
.storefront-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
  align-items: start;
}
@media (min-width: 640px) {
  .storefront-row {
    grid-template-columns: repeat(3, 1fr);
  }
}
</style>
