---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FAQ from "../../components/FAQ.astro";
import CTA from "../../components/CTA.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const list = await getCollection("listicles");
  return list.map(post => ({ params: { slug: post.slug }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await post.render();
const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: post.data.entries.map(e => ({
    "@type": "ListItem",
    position: e.rank,
    name: e.name,
    url: e.url
  }))
};
const sortedEntries = post.data.entries.slice().sort((a, b) => a.rank - b.rank);
---
<BaseLayout
  title={`${post.data.title}: Win-Win Apps`}
  description={post.data.description}
  current="best"
  schema={itemList}
>
  <section class="hero hero-compact">
    <div class="container">
      <p class="eyebrow">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="hero-lead">{post.data.description}</p>
      <p style="margin-top:12px;font-size:14px;color:var(--color-brown-secondary)">Updated {post.data.updatedAt.toISOString().slice(0, 10)}</p>
    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <div class="listicle-grid">
        {sortedEntries.map(e => (
          <article class={`listicle-card ${e.isOurs ? "listicle-card-ours" : ""}`}>
            <div class="listicle-rank-row">
              <span class="rank-pill">{`#${e.rank}`}</span>
              {e.isOurs && <span class="ours-pill">Our app</span>}
            </div>

            <header class="listicle-head">
              <h3 class="listicle-title">{e.name}</h3>
              <p class="listicle-meta">{e.pricing}{e.rating ? ` · ${e.rating} ★` : ""}</p>
              <p class="listicle-tagline">{e.tagline}</p>
            </header>

            <div class="listicle-divider"></div>

            <section class="listicle-section">
              <p class="section-label">Best for</p>
              <p class="section-body">{e.bestFor}</p>
            </section>

            <div class="listicle-divider"></div>

            <section class="listicle-section">
              <p class="section-label">Pros</p>
              <ul class="pros-list">
                {e.pros.map(p => <li>{p}</li>)}
              </ul>
            </section>

            <div class="listicle-divider"></div>

            <section class="listicle-section">
              <p class="section-label">Cons</p>
              <ul class="cons-list">
                {e.cons.map(c => <li>{c}</li>)}
              </ul>
            </section>

            {e.url && (
              <div class="listicle-cta">
                <a href={e.url} target="_blank" rel="noopener" class={`btn ${e.isOurs ? "btn-primary" : "btn-secondary"}`}>
                  {e.isOurs ? "Install on Shopify" : "View on Shopify ↗"}
                </a>
              </div>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container container-narrow prose">
      <Content />
    </div>
  </section>

  {post.data.faqs && post.data.faqs.length > 0 && (
    <section class="section">
      <div class="container container-narrow">
        <FAQ items={post.data.faqs} />
      </div>
    </section>
  )}

  <section class="section section-alt">
    <div class="container container-narrow">
      <CTA
        heading="Try one of our Shopify apps free."
        body="Every app has a real free tier. Install in minutes."
        primaryLabel="See all apps"
        primaryHref="/apps/"
        secondaryLabel="Contact us"
        secondaryHref="/contact/"
      />
    </div>
  </section>
</BaseLayout>

<style>
.listicle-grid {
  display: grid;
  gap: 28px;
  grid-template-columns: 1fr;
}
@media (min-width: 720px) {
  .listicle-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (min-width: 1100px) {
  .listicle-grid { grid-template-columns: repeat(3, 1fr); }
}
.listicle-card {
  background: var(--color-white);
  border: 1px solid var(--color-brown-outline);
  border-radius: 16px;
  padding: 28px;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-sm);
}
.listicle-card-ours {
  border: 2px solid var(--color-blush-deep);
  box-shadow: 0 4px 16px rgba(165, 54, 48, 0.08);
}
.listicle-rank-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 18px;
}
.rank-pill {
  background: #d7eed0;
  color: #1d6b2f;
  font-weight: 700;
  font-size: 13px;
  padding: 4px 12px;
  border-radius: 999px;
  letter-spacing: 0.02em;
}
.ours-pill {
  background: var(--color-blush-deep);
  color: #fff;
  font-weight: 700;
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 999px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.listicle-head { margin-bottom: 18px; }
.listicle-title {
  font-family: var(--font-serif);
  font-size: 24px;
  line-height: 1.2;
  margin: 0 0 10px;
  color: var(--color-dark-brown);
}
.listicle-meta {
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-brown-secondary);
  margin: 0 0 12px;
  font-weight: 600;
}
.listicle-tagline {
  color: var(--color-brown-secondary);
  font-size: 15px;
  line-height: 1.5;
  margin: 0;
}
.listicle-divider {
  height: 1px;
  background: rgba(58, 46, 42, 0.1);
  margin: 18px 0;
}
.listicle-section {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.section-label {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: 700;
  color: var(--color-dark-brown);
  margin: 0;
}
.section-body {
  margin: 0;
  font-size: 15px;
  line-height: 1.5;
  color: var(--color-brown-secondary);
}
.pros-list, .cons-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.pros-list li, .cons-list li {
  position: relative;
  padding-left: 24px;
  font-size: 15px;
  line-height: 1.5;
  color: var(--color-dark-brown);
}
.pros-list li::before {
  content: "✓";
  position: absolute;
  left: 0;
  top: 0;
  color: #1d6b2f;
  font-weight: 700;
}
.cons-list li::before {
  content: "×";
  position: absolute;
  left: 2px;
  top: -1px;
  color: #a53630;
  font-weight: 700;
  font-size: 18px;
  line-height: 1.3;
}
.listicle-cta {
  margin-top: 22px;
  padding-top: 20px;
  border-top: 1px solid rgba(58, 46, 42, 0.08);
}
.listicle-cta .btn {
  width: 100%;
  text-align: center;
  padding: 12px 16px;
  font-size: 14px;
}
</style>
