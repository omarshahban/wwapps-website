---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FAQ from "../../components/FAQ.astro";
import CTA from "../../components/CTA.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const list = await getCollection("listicles");
  return list.map(post => ({ params: { slug: post.slug }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await post.render();
const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  itemListElement: post.data.entries.map(e => ({
    "@type": "ListItem",
    position: e.rank,
    name: e.name,
    url: e.url
  }))
};
---
<BaseLayout
  title={`${post.data.title}: Win-Win Apps`}
  description={post.data.description}
  current="best"
  schema={itemList}
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="hero-lead">{post.data.description}</p>
      <p style="margin-top:12px;font-size:14px;color:var(--color-text-muted)">Updated {post.data.updatedAt.toISOString().slice(0, 10)}</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid">
        {post.data.entries.sort((a, b) => a.rank - b.rank).map(e => (
          <article class={`card ${e.isOurs ? "card-highlight" : ""}`}>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
              <span class="badge badge-live" style="font-size:12px">{`#${e.rank}`}</span>
              {e.isOurs && <span class="badge" style="background:var(--color-blush-deep);color:white;font-size:12px">Our app</span>}
            </div>
            <h3 style="margin:0 0 6px">{e.name}</h3>
            <p class="eyebrow" style="margin-bottom:6px">{e.pricing}{e.rating ? ` · ${e.rating} ★` : ""}</p>
            <p>{e.tagline}</p>
            <p style="font-weight:600;margin-top:10px;margin-bottom:4px">Best for:</p>
            <p>{e.bestFor}</p>
            <p style="font-weight:600;margin-top:10px;margin-bottom:4px">Pros</p>
            <ul class="checklist">{e.pros.map(p => <li>{p}</li>)}</ul>
            <p style="font-weight:600;margin-top:10px;margin-bottom:4px">Cons</p>
            <ul class="checklist" style="--mark-color: var(--color-brown)">{e.cons.map(c => <li style="list-style:disc">{c}</li>)}</ul>
            {e.url && <p style="margin-top:14px"><a href={e.url} target="_blank" rel="noopener" class="btn btn-secondary" style="padding:10px 18px;font-size:14px">View on Shopify</a></p>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container container-narrow prose">
      <Content />
    </div>
  </section>

  {post.data.faqs && post.data.faqs.length > 0 && (
    <section class="section">
      <div class="container container-narrow">
        <FAQ items={post.data.faqs} />
      </div>
    </section>
  )}

  <section class="section section-alt">
    <div class="container container-narrow">
      <CTA
        heading="Try one of our Shopify apps free."
        body="Every app has a real free tier. Install in minutes."
        primaryLabel="See all apps"
        primaryHref="/apps/"
        secondaryLabel="Contact us"
        secondaryHref="/contact/"
      />
    </div>
  </section>
</BaseLayout>
