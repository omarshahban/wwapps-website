---
import BaseLayout from "../../layouts/BaseLayout.astro";
import IndexCard from "../../components/IndexCard.astro";
import { getCollection } from "astro:content";
const entries = (await getCollection("listicles")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const categoryAccent: Record<string, string> = {
  Conversion: "#a53630",
  Loyalty: "#2e6b43",
  Merchandising: "#1d4e8a",
  Fulfillment: "#8a5a17"
};
---
<BaseLayout
  title="Best Shopify apps: roundups by Win-Win Apps"
  description="Honest round-ups of the top Shopify apps in each category. We include our apps and our competitors side by side."
  current="best"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Roundups</p>
      <h1>Best Shopify apps, category by category.</h1>
      <p class="hero-lead">Picked from hundreds of apps. Real pros and cons, including our own.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      {entries.length === 0 && <p>Roundups are coming soon.</p>}
      <div class="grid grid-2">
        {entries.map(e => (
          <IndexCard
            href={`/best/${e.slug}/`}
            eyebrow={e.data.category}
            title={e.data.title}
            description={e.data.description}
            meta={`${e.data.entries.length} apps reviewed`}
            accent={categoryAccent[e.data.category] || "#a53630"}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
