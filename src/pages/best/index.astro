---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
const entries = (await getCollection("listicles")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---
<BaseLayout
  title="Best Shopify apps: roundups by Win-Win Apps"
  description="Honest round-ups of the top Shopify apps in each category. We include our apps and our competitors side by side."
  current="best"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Roundups</p>
      <h1>Best Shopify apps, category by category.</h1>
      <p class="hero-lead">Picked from hundreds of apps. Real pros and cons, including our own.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      {entries.length === 0 && <p>Roundups are coming soon.</p>}
      <div class="grid grid-2">
        {entries.map(e => (
          <a class="card" href={`/best/${e.slug}/`} style="text-decoration:none;color:inherit">
            <p class="eyebrow">{e.data.category}</p>
            <h3 style="margin:6px 0 10px">{e.data.title}</h3>
            <p>{e.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
