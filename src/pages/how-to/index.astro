---
import BaseLayout from "../../layouts/BaseLayout.astro";
import IndexCard from "../../components/IndexCard.astro";
import { getCollection } from "astro:content";
const entries = (await getCollection("howto")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const categoryAccent: Record<string, string> = {
  Conversion: "#a53630",
  Loyalty: "#2e6b43",
  Merchandising: "#1d4e8a",
  Fulfillment: "#8a5a17"
};

// Group by category for visual separation
const grouped: Record<string, typeof entries> = {};
for (const e of entries) {
  const cat = e.data.category || "Other";
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(e);
}
const categories = Object.keys(grouped).sort();
---
<BaseLayout
  title="How-to guides: Win-Win Apps"
  description="Step-by-step guides for common Shopify merchant tasks. Short, clear, screenshotted."
  current="how-to"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Guides</p>
      <h1>How-to guides for Shopify merchants.</h1>
      <p class="hero-lead">The exact steps to get things done on your store. No theory, just clicks.</p>
      <div class="hero-actions">
        <span class="stat-pill"><strong>{entries.length}</strong> guides</span>
        <span class="stat-pill"><strong>{categories.length}</strong> categories</span>
      </div>
    </div>
  </section>
  {entries.length === 0 && (
    <section class="section"><div class="container"><p>New guides are on the way.</p></div></section>
  )}
  {categories.map(cat => (
    <section class="section">
      <div class="container">
        <div class="section-head" style="margin-bottom:20px">
          <p class="eyebrow">{cat}</p>
          <h2 style="margin:0">{cat} guides</h2>
        </div>
        <div class="grid grid-2">
          {grouped[cat].map(e => (
            <IndexCard
              href={`/how-to/${e.slug}/`}
              eyebrow={`${e.data.readingTime || 5} min read`}
              title={e.data.title}
              description={e.data.description}
              accent={categoryAccent[cat] || "#a53630"}
            />
          ))}
        </div>
      </div>
    </section>
  ))}
</BaseLayout>

<style>
.stat-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  border-radius: 999px;
  background: #fff;
  border: 1px solid var(--color-brown-outline);
  font-size: 14px;
  color: var(--color-brown-secondary);
}
.stat-pill strong {
  font-family: var(--font-serif);
  font-size: 17px;
  color: var(--color-blush-deep);
}
</style>
