---
import BaseLayout from "../layouts/BaseLayout.astro";
import AppCard from "../components/AppCard.astro";
import Testimonial from "../components/Testimonial.astro";
import CTA from "../components/CTA.astro";
import { getCollection } from "astro:content";

const apps = (await getCollection("apps")).sort((a, b) => {
  const order: Record<string, number> = { live: 0, beta: 1, "coming-soon": 2 };
  return (order[a.data.status] ?? 9) - (order[b.data.status] ?? 9);
});
const liveApps = apps.filter(a => a.data.status === "live");

const testimonials = [
  { quote: "amazing support, great features, and is incredibly easy to use", author: "Store Credit merchant", rating: 5 },
  { quote: "Bulk store credit tool works immaculately. Saved us hours every week.", author: "Store Credit merchant", rating: 5 },
  { quote: "Finally a badge app that does not hide basic stuff behind a paywall. Installed in five minutes.", author: "Product Badges merchant", rating: 5 }
];
---
<BaseLayout
  title="Win-Win Apps: honest Shopify apps with real free tiers"
  description="Simple, focused Shopify apps for real merchant problems. Every app has a meaningful free tier. No dark patterns, no lock-in, no painful pricing."
  current=""
>
  <section class="hero hero-visual">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Shopify apps for merchants</p>
        <h1>Small apps, real free tiers, zero friction.</h1>
        <p class="hero-lead">We build focused Shopify apps for the everyday problems merchants actually have. Install in minutes, stop thinking about it, get back to selling.</p>
        <div class="hero-actions">
          <a href="/apps/" class="btn btn-primary">See all apps</a>
          <a href="/compare/" class="btn btn-secondary">How we compare</a>
        </div>
        <div class="stat-strip">
          <div class="stat-item"><strong>{liveApps.length}</strong><span>Published apps</span></div>
          <div class="stat-item"><strong>5.0★</strong><span>Average rating</span></div>
          <div class="stat-item"><strong>Free</strong><span>Real free tier</span></div>
          <div class="stat-item"><strong>24h</strong><span>Support response</span></div>
        </div>
      </div>
      <div class="hero-visual-grid" aria-hidden="true">
        {apps.slice(0, 4).map(app => (
          <a href={`/apps/${app.slug}/`} class="hero-app-tile" title={app.data.name}>
            <img src={app.data.logo || "/assets/Win-Win%20apps.png"} alt="" width="120" height="120" loading="eager" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Our apps</p>
        <h2>Pick the one that solves your problem today.</h2>
        <p>Each app does one job. Install one, a few, or all of them.</p>
      </div>
      <div class="grid">
        {apps.map(app => <AppCard app={app} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Why merchants pick us</p>
        <h2>The things that matter, done properly.</h2>
      </div>
      <div class="grid grid-3">
        <div class="feature-tile">
          <div class="feature-icon" aria-hidden="true">✓</div>
          <h3>Real free tier</h3>
          <p>Not a trial. A real plan you can run forever. Paid tiers kick in only when you outgrow the limits.</p>
        </div>
        <div class="feature-tile">
          <div class="feature-icon" aria-hidden="true">⚡</div>
          <h3>5-minute setup</h3>
          <p>App embed install, no theme edits, no developer needed. You click install and it works.</p>
        </div>
        <div class="feature-tile">
          <div class="feature-icon" aria-hidden="true">♡</div>
          <h3>Support that replies</h3>
          <p>You email us, you get one of us back within 24 hours. No ticket queue, no outsourced first line.</p>
        </div>
        <div class="feature-tile">
          <div class="feature-icon" aria-hidden="true">◇</div>
          <h3>No lock-in</h3>
          <p>Your settings and data live on Shopify metafields. Uninstall clean, no leftover code.</p>
        </div>
        <div class="feature-tile">
          <div class="feature-icon" aria-hidden="true">↻</div>
          <h3>Fast shipping</h3>
          <p>We ship new apps weekly and new features every few days. Merchant feedback gets built fast.</p>
        </div>
        <div class="feature-tile">
          <div class="feature-icon" aria-hidden="true">$</div>
          <h3>Honest pricing</h3>
          <p>We never gate obvious features to force an upgrade. Pay for real extras, not basics.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Merchants say</p>
        <h2>Real reviews from real stores.</h2>
      </div>
      <div class="grid grid-3">
        {testimonials.map(t => <Testimonial quote={t.quote} author={t.author} rating={t.rating} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container-narrow">
      <CTA
        heading="Stop paying for basic features."
        body="Install any of our apps free from the Shopify App Store in minutes."
        primaryLabel="Browse all apps"
        primaryHref="/apps/"
        secondaryLabel="Read our blog"
        secondaryHref="/blog/"
      />
    </div>
  </section>
</BaseLayout>
