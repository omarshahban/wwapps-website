---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FAQ from "../../components/FAQ.astro";
import CTA from "../../components/CTA.astro";
import Testimonial from "../../components/Testimonial.astro";
import AppHeroVisual from "../../components/visuals/AppHeroVisual.astro";
import StepFlow from "../../components/visuals/StepFlow.astro";
import StatBlock from "../../components/visuals/StatBlock.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const apps = await getCollection("apps");
  return apps.map(app => ({ params: { slug: app.slug }, props: { app } }));
}
const { app } = Astro.props;
const { Content } = await app.render();

// related content for internal linking
const allListicles = await getCollection("listicles");
const allCompares = await getCollection("comparisons");
const allHowtos = await getCollection("howto");

const relatedListicles = allListicles.filter(l =>
  l.data.entries?.some((e: any) => e.isOurs) &&
  l.data.category === app.data.category
).slice(0, 5);

const relatedCompares = allCompares.filter(c => c.data.ourApp === app.slug).slice(0, 5);
const relatedHowtos = allHowtos.filter(h => h.data.relatedApp === app.slug).slice(0, 8);

const stepMap: Record<string, any[]> = {
  "win-win-product-badges": [
    { icon: "⚙️", title: "Install in 30 seconds", body: "One click install from the Shopify App Store. No theme edits, no developers." },
    { icon: "🎨", title: "Pick a badge style", body: "Choose from our library or build a custom badge with your brand colors." },
    { icon: "🎯", title: "Target by rule", body: "Show badges by tag, collection, price drop, or inventory level. Zero manual work." }
  ],
  "win-win-store-credit": [
    { icon: "📥", title: "Upload a CSV", body: "Bulk issue credit to a segment of customers in under a minute. No per-customer clicks." },
    { icon: "💳", title: "Customers see balance", body: "Credit shows on account pages and at checkout, styled to match your theme." },
    { icon: "🧾", title: "Auto-apply at checkout", body: "Credit applies on click. Full audit log for every issue and redemption." }
  ],
  "arrively": [
    { icon: "📅", title: "Pick your cutoff", body: "Set the daily order cutoff time per zone. Weekends and holidays respected automatically." },
    { icon: "🚚", title: "Dates show on products", body: "Shoppers see the earliest delivery date right below Add to Cart, before they bounce." },
    { icon: "📦", title: "Dates carry to checkout", body: "ETA is confirmed on cart, checkout, and the confirmation email. No surprises." }
  ],
  "made-in": [
    { icon: "🌍", title: "Tag products with origin", body: "Bulk-assign country of origin by collection, tag, or CSV. One-time setup." },
    { icon: "🏷️", title: "Badges render on storefront", body: "Flag + country shows on product cards and product pages. Theme-agnostic, no code." },
    { icon: "🛒", title: "Filter by country", body: "Shoppers can filter Made In USA, Made in Italy, anywhere you sell from. Good for trade-war SEO." }
  ]
};
const steps = stepMap[app.slug] || null;

const statMap: Record<string, any[]> = {
  "win-win-product-badges": [
    { value: "Free", label: "Plan with 2 badges" },
    { value: "$6.99", label: "Pro, unlimited" },
    { value: "30s", label: "Install time" },
    { value: "0", label: "Coding required" }
  ],
  "win-win-store-credit": [
    { value: "Free", label: "10-row CSV tier" },
    { value: "$49", label: "Pro, unlimited CSV" },
    { value: "5.0★", label: "7 reviews" },
    { value: "All plans", label: "Works on every tier" }
  ],
  "arrively": [
    { value: "Zones", label: "Per-region ETAs" },
    { value: "Auto", label: "Holiday skip" },
    { value: "PDP", label: "Dates on product page" },
    { value: "Free", label: "Up to 50 orders" }
  ],
  "made-in": [
    { value: "240+", label: "Flags supported" },
    { value: "Tag", label: "Or collection rules" },
    { value: "Cards", label: "PDP + collection" },
    { value: "Free", label: "Starter tier" }
  ]
};
const stats = statMap[app.slug] || null;

const schema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: app.data.name,
  description: app.data.description,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web, Shopify",
  offers: {
    "@type": "Offer",
    price: app.data.pricing?.free ? "0" : (app.data.pricing?.paid?.[0]?.price || "0"),
    priceCurrency: "USD"
  },
  aggregateRating: app.data.rating ? {
    "@type": "AggregateRating",
    ratingValue: String(app.data.rating),
    reviewCount: String(app.data.reviewCount || 1)
  } : undefined,
  url: `https://wwapps.io/apps/${app.slug}/`
};
---
<BaseLayout
  title={`${app.data.name}: ${app.data.tagline}`}
  description={app.data.description}
  current="apps"
  schema={schema}
>
  <section class="hero app-hero">
    <div class="container app-hero-grid">
      <div class="app-hero-copy">
        <p class="eyebrow">{app.data.category}</p>
        <h1>{app.data.name}</h1>
        <p class="hero-lead">{app.data.tagline}</p>
        <div class="hero-actions">
          {app.data.shopifyUrl ? (
            <a href={app.data.shopifyUrl} target="_blank" rel="noopener" class="btn btn-primary">Install Free on Shopify</a>
          ) : (
            <a href="/contact/" class="btn btn-primary">Join the waitlist</a>
          )}
          <a href="#pricing" class="btn btn-secondary">See pricing</a>
        </div>
      </div>
      <AppHeroVisual slug={app.slug} />
    </div>
  </section>

  {stats && (
    <section class="section section-thin">
      <div class="container container-narrow">
        <StatBlock stats={stats} />
      </div>
    </section>
  )}

  {steps && (
    <section class="section section-alt">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">How it works</p>
          <h2>Three steps, no developer needed.</h2>
        </div>
        <StepFlow steps={steps} />
      </div>
    </section>
  )}

  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">What it does</p>
        <h2>Everything included.</h2>
      </div>
      <ul class="checklist feature-list" style="max-width: 960px;">
        {app.data.features.map((f: string) => <li>{f}</li>)}
      </ul>
    </div>
  </section>

  {app.data.pricing && (
    <section id="pricing" class="section">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Pricing</p>
          <h2>Free to start. Honest paid plans.</h2>
        </div>
        <div class="grid grid-2">
          {app.data.pricing.free && (
            <div class="card">
              <span class="badge badge-live">Free</span>
              <h3 style="margin-top:12px">Free plan</h3>
              <p>{app.data.pricing.free}</p>
            </div>
          )}
          {app.data.pricing.paid?.map((plan: any) => (
            <div class="card">
              <h3>{plan.name}</h3>
              <p style="font-family:var(--font-serif);font-size:32px;color:var(--color-blush-deep);margin:0 0 12px">{plan.price}</p>
              <ul class="checklist">
                {plan.includes.map((i: string) => <li>{i}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  {app.data.testimonials && app.data.testimonials.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Reviews</p>
          <h2>Real feedback from merchants using this app.</h2>
        </div>
        <div class="grid grid-3">
          {app.data.testimonials.map((t: any) => (
            <Testimonial quote={t.quote} author={t.author} rating={t.rating} />
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section">
    <div class="container container-narrow prose">
      <Content />
    </div>
  </section>

  {app.data.faqs && app.data.faqs.length > 0 && (
    <section class="section section-alt">
      <div class="container container-narrow">
        <FAQ items={app.data.faqs} />
      </div>
    </section>
  )}

  {(relatedHowtos.length > 0 || relatedCompares.length > 0 || relatedListicles.length > 0) && (
    <section class="section">
      <div class="container container-narrow">
        <div class="section-head">
          <p class="eyebrow">Keep reading</p>
          <h2>Guides and comparisons for this app.</h2>
        </div>
        {relatedHowtos.length > 0 && (
          <div style="margin-bottom:28px">
            <h3 style="margin:0 0 10px">How-to guides</h3>
            <ul>
              {relatedHowtos.map(h => (
                <li style="margin:6px 0"><a href={`/how-to/${h.slug}/`}>{h.data.title}</a></li>
              ))}
            </ul>
          </div>
        )}
        {relatedCompares.length > 0 && (
          <div style="margin-bottom:28px">
            <h3 style="margin:0 0 10px">Compare</h3>
            <ul>
              {relatedCompares.map(c => (
                <li style="margin:6px 0"><a href={`/compare/${c.slug}/`}>{c.data.title}</a></li>
              ))}
            </ul>
          </div>
        )}
        {relatedListicles.length > 0 && (
          <div>
            <h3 style="margin:0 0 10px">Best-of lists</h3>
            <ul>
              {relatedListicles.map(l => (
                <li style="margin:6px 0"><a href={`/best/${l.slug}/`}>{l.data.title}</a></li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  <section class="section">
    <div class="container container-narrow">
      <CTA
        heading={`Try ${app.data.name} on your store today.`}
        body="Free tier on every app. No credit card to install."
        primaryLabel={app.data.shopifyUrl ? "Install Free on Shopify" : "Join the waitlist"}
        primaryHref={app.data.shopifyUrl || "/contact/"}
        secondaryLabel="See all apps"
        secondaryHref="/apps/"
      />
    </div>
  </section>
</BaseLayout>
