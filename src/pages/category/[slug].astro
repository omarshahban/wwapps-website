---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AppCard from "../../components/AppCard.astro";
import IndexCard from "../../components/IndexCard.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const apps = await getCollection("apps");
  const cats = Array.from(new Set(apps.map(a => a.data.category)));
  return cats.map(cat => ({
    params: { slug: cat.toLowerCase() },
    props: { category: cat }
  }));
}

const { category } = Astro.props;
const apps = (await getCollection("apps")).filter(a => a.data.category === category);
const listicles = (await getCollection("listicles")).filter(l => l.data.category === category);
const howtos = (await getCollection("howto")).filter(h => h.data.category === category);

const blurb: Record<string, string> = {
  "Conversion": "Apps that lift conversion rate on product and collection pages. Badges, delivery dates, origin labels, the things shoppers look for before they hit buy.",
  "Loyalty": "Apps that keep customers coming back. Store credit, rewards, retention tools, all with a generous free tier.",
  "Merchandising": "Ways to present products well so the right items get seen by the right shoppers.",
  "Fulfillment": "Delivery, shipping, and post-purchase clarity for merchants who want fewer where-is-my-order emails."
};

const accent: Record<string, string> = {
  Conversion: "#a53630",
  Loyalty: "#2e6b43",
  Merchandising: "#1d4e8a",
  Fulfillment: "#8a5a17"
};
const catAccent = accent[category] || "#a53630";
---
<BaseLayout
  title={`${category} Shopify apps and guides — Win-Win Apps`}
  description={`Shopify ${category.toLowerCase()} apps, comparisons, and how-to guides from Win-Win Apps.`}
>
  <section class="hero">
    <div class="container container-narrow">
      <p class="eyebrow" style={`color:${catAccent}`}>Category</p>
      <h1>{category} apps for Shopify.</h1>
      <p class="hero-lead">{blurb[category] || `Our Shopify ${category.toLowerCase()} apps, plus comparisons and how-tos for merchants.`}</p>
      <div class="category-stats">
        <span class="meta-pill"><strong>{apps.length}</strong> apps</span>
        <span class="meta-pill"><strong>{listicles.length}</strong> roundups</span>
        <span class="meta-pill"><strong>{howtos.length}</strong> how-to guides</span>
      </div>
    </div>
  </section>

  {apps.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Our apps</p>
          <h2 style="margin:0">{category} apps built by Win-Win</h2>
        </div>
        <div class={apps.length === 4 ? "grid-4" : "grid"}>
          {apps.map(app => <AppCard app={app} />)}
        </div>
      </div>
    </section>
  )}

  {listicles.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Best-of roundups</p>
          <h2 style="margin:0">Top {category.toLowerCase()} apps, ranked</h2>
        </div>
        <div class="grid grid-2">
          {listicles.map(l => (
            <IndexCard
              href={`/best/${l.slug}/`}
              eyebrow={category}
              title={l.data.title}
              description={l.data.description}
              meta={`${l.data.entries.length} apps reviewed`}
              accent={catAccent}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {howtos.length > 0 && (
    <section class="section">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">How-to guides</p>
          <h2 style="margin:0">Step-by-step {category.toLowerCase()} guides</h2>
        </div>
        <div class="grid grid-2">
          {howtos.map(h => (
            <IndexCard
              href={`/how-to/${h.slug}/`}
              eyebrow={`${h.data.readingTime || 5} min read`}
              title={h.data.title}
              description={h.data.description}
              accent={catAccent}
            />
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
.category-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 20px;
}
.meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 14px;
  border-radius: 999px;
  background: #fff;
  border: 1px solid var(--color-brown-outline);
  font-size: 13px;
  color: var(--color-brown-secondary);
}
.meta-pill strong {
  font-family: var(--font-serif);
  font-size: 15px;
  color: var(--color-blush-deep);
}
</style>
