---
import BaseLayout from "../../layouts/BaseLayout.astro";
import IndexCard from "../../components/IndexCard.astro";
import { getCollection } from "astro:content";
const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

function formatDate(d: Date) {
  return d.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}
---
<BaseLayout
  title="Win-Win Apps blog: Shopify notes and playbooks"
  description="Short, practical posts on Shopify growth, pricing, and app building."
  current="blog"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Writing</p>
      <h1>Notes from shipping Shopify apps.</h1>
      <p class="hero-lead">What we learned, what broke, what worked. Short and practical, no fluff.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length === 0 && (
        <p>New posts are on the way. Check back soon.</p>
      )}
      <div class="grid grid-2">
        {posts.map(post => (
          <IndexCard
            href={`/blog/${post.slug}/`}
            eyebrow={formatDate(post.data.publishedAt)}
            title={post.data.title}
            description={post.data.description}
            meta={post.data.tags && post.data.tags.length > 0 ? post.data.tags.join(" · ") : undefined}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
