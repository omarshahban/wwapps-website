---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Page not found" description="That page could not be found." current="">
  <section class="section" style="min-height: 60vh; display:flex; align-items:center">
    <div class="container container-narrow" style="text-align:center">
      <p class="eyebrow">404</p>
      <h1>This page doesn't exist.</h1>
      <p class="muted">It may have moved, or the link might be wrong. Try one of these instead:</p>
      <div class="hero-actions" style="justify-content:center;margin-top:24px">
        <a href="/" class="btn btn-primary">Home</a>
        <a href="/apps/" class="btn btn-secondary">Browse apps</a>
        <a href="/blog/" class="btn btn-secondary">Blog</a>
      </div>
    </div>
  </section>
</BaseLayout>
