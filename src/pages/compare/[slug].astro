---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ComparisonTable from "../../components/ComparisonTable.astro";
import FAQ from "../../components/FAQ.astro";
import CTA from "../../components/CTA.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const list = await getCollection("comparisons");
  return list.map(post => ({ params: { slug: post.slug }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await post.render();
---
<BaseLayout
  title={`${post.data.title}: Win-Win Apps`}
  description={post.data.description}
  current="compare"
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Comparison</p>
      <h1>{post.data.title}</h1>
      <p class="hero-lead">{post.data.description}</p>
      <p style="margin-top:12px;font-size:14px;color:var(--color-text-muted)">Updated {post.data.updatedAt.toISOString().slice(0, 10)}</p>
    </div>
  </section>

  <section class="section">
    <div class="container container-narrow">
      <div class="callout" style="margin-bottom:32px">
        <h3 style="margin:0 0 8px">Short answer</h3>
        <p style="margin:0">{post.data.verdictSummary}</p>
      </div>
      <ComparisonTable
        ours={post.data.ourApp}
        theirs={post.data.competitor}
        rows={post.data.matrix}
      />
    </div>
  </section>

  <section class="section section-alt">
    <div class="container container-narrow prose">
      <Content />
    </div>
  </section>

  {post.data.faqs && post.data.faqs.length > 0 && (
    <section class="section">
      <div class="container container-narrow">
        <FAQ items={post.data.faqs} />
      </div>
    </section>
  )}

  <section class="section section-alt">
    <div class="container container-narrow">
      <CTA
        heading={`Try ${post.data.ourApp} on your store today.`}
        body="Free tier on every app. No credit card to install."
        primaryLabel="See the app"
        primaryHref="/apps/"
        secondaryLabel="Contact us"
        secondaryHref="/contact/"
      />
    </div>
  </section>
</BaseLayout>
